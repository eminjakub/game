<Application x:Class="game.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:game"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <Style TargetType="Button" x:Key="GameButton">
            <Setter Property="FontFamily" Value="Viner Hand ITC"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#CC3A3A3A" BorderBrush="#88FFFFFF" BorderThickness="1" CornerRadius="5" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC5A5A5A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CCFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ShopBuyButton">
            <Setter Property="FontFamily" Value="Viner Hand ITC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#CC2E7D32" BorderBrush="#88FFFFFF" BorderThickness="1" CornerRadius="4" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC43A047"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label" x:Key="GameLabel">
            <Setter Property="FontFamily" Value="Viner Hand ITC"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
        </Style>

        <Style TargetType="Label" x:Key="GameLabelGold">
            <Setter Property="FontFamily" Value="Viner Hand ITC"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#FFFFD700"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="DialogText">
            <Setter Property="FontFamily" Value="Viner Hand ITC"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="Border" x:Key="DialogPanel">
            <Setter Property="Background" Value="#DD2A2A2A"/>
            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style TargetType="Border" x:Key="ItemCard">
            <Setter Property="Background" Value="#CC333333"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style TargetType="ProgressBar" x:Key="GameHPBar">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="#FFDC0000"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ProgressBar" x:Key="GameStatBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Application.Resources>
</Application>
