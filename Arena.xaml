<Page x:Class="game.Arena"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="Arena"  Height="720" Width="1280">

    <Grid>
        <Image Source="./fotky/arena.jpg" Stretch="Fill"/>

        <!-- Home button -->
        <Button Click="Get_home" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Height="70" Width="70" Background="{x:Null}" BorderBrush="{x:Null}" Cursor="Hand">
            <Image Height="60" Source="/fotky/home_button.png" Stretch="Fill" Width="60"/>
        </Button>

        <!-- Enemy selection panel -->
        <Border x:Name="enemySelectPanel" Style="{StaticResource DialogPanel}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="800" Visibility="Visible">
            <StackPanel>
                <TextBlock Text="Vyber si protivníka!" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <ItemsControl x:Name="enemyListControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ItemCard}" Width="230" Margin="8" Cursor="Hand">
                                <Button Background="{x:Null}" BorderBrush="{x:Null}" Click="SelectEnemy_Click" Tag="{Binding}" Cursor="Hand">
                                    <StackPanel>
                                        <Image Source="{Binding ImagePath}" Height="100" Width="100" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontFamily="Viner Hand ITC" FontSize="20" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <TextBlock Foreground="#AAAAAA" FontFamily="Viner Hand ITC" FontSize="13" HorizontalAlignment="Center">
                                            <Run Text="HP: "/><Run Text="{Binding max_health}"/>
                                            <Run Text=" | STR: "/><Run Text="{Binding strenght}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="13" HorizontalAlignment="Center">
                                            <Run Text="Odměna: "/><Run Text="{Binding reward_money}"/><Run Text=" Gold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Fight UI -->
        <Grid x:Name="fightPanel" Visibility="Hidden">
            <!-- Enemy side (top) -->
            <Border Style="{StaticResource DialogPanel}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,40,0" Width="350">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image x:Name="enemy_fight_img" Height="80" Width="80" Stretch="Uniform" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="enemy_name_label" Text="Nepřítel" Foreground="#FFFF6666" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold"/>
                            <ProgressBar x:Name="enemy_hp_bar" Style="{StaticResource GameHPBar}" Width="180" Minimum="0" Maximum="100" Value="100"/>
                            <TextBlock x:Name="enemy_hp_text" Text="100/100 HP" Foreground="#CCCCCC" FontFamily="Viner Hand ITC" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Player side (bottom left) -->
            <Border Style="{StaticResource DialogPanel}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,20" Width="350">
                <StackPanel>
                    <TextBlock Text="Tvůj hrdina" Foreground="#FF66FF66" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold"/>
                    <ProgressBar x:Name="player_hp_bar" Height="20" Foreground="#FF00CC00" Background="#FF333333" BorderBrush="#88FFFFFF" BorderThickness="1" Width="280" Minimum="0" Maximum="100" Value="100"/>
                    <TextBlock x:Name="player_hp_text" Text="100/100 HP" Foreground="#CCCCCC" FontFamily="Viner Hand ITC" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button x:Name="attack_button" Content="Útok!" Style="{StaticResource GameButton}" Margin="5" Click="Attack_Click" Width="120"/>
                        <Button x:Name="potion_button" Content="Lektvar" Style="{StaticResource ShopBuyButton}" Margin="5" Click="UsePotion_Click" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Battle log -->
            <Border Style="{StaticResource DialogPanel}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" Width="460" MaxHeight="250">
                <ScrollViewer x:Name="logScroll" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="battle_log_text" Style="{StaticResource DialogText}" FontSize="14"/>
                </ScrollViewer>
            </Border>

            <!-- Result overlay -->
            <Border x:Name="resultPanel" Visibility="Hidden" Background="#DD000000" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40,30">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="result_text" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="36" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Button Content="Zpět do arény" Style="{StaticResource GameButton}" Click="BackToSelect_Click" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
