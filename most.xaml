<Page x:Class="game.Most"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="most">

    <Grid>
        <Image Stretch="Fill" Source="./fotky/most.png"/>

        <!-- Home button -->
        <Button Click="Get_home" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Height="72" Width="77" Background="{x:Null}" BorderBrush="{x:Null}" Cursor="Hand">
            <Image Height="72" Source="/fotky/home_button.png" Stretch="Fill" Width="67"/>
        </Button>

        <!-- Dealeros standing character -->
        <Button HorizontalAlignment="Center" Margin="0,296,0,0" VerticalAlignment="Top" Height="202" Width="210"
                Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}"
                Click="dealeros_button_click_shop" Cursor="Hand"
                x:Name="dealeros_standing_btn">
            <Image x:Name="dealeros_velky_img" Height="192" Stretch="Fill"
                   Source="./fotky/dealeros_postava_velka.png" Width="198"/>
        </Button>

        <!-- Full dialog + shop overlay -->
        <Border x:Name="dealeros_panel" Visibility="Hidden" Background="#EE111111"
                CornerRadius="10" Margin="30,20,30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Dealeros portrait + dialog -->
                <Border Style="{StaticResource DialogPanel}" Margin="15,15,8,15">
                    <StackPanel>
                        <Image Source="./fotky/dealeros.png" Height="130" Width="110" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Dealeros" Foreground="#FF00FF88" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="dealeros_dialog_label" Style="{StaticResource DialogText}" FontSize="14" Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Text="Pssst! Hej ty! Pojď sem...&#x0a;&#x0a;Mám tu speciální zboží, co jinde neseženeš. Informace, kontakty, houbičky...&#x0a;&#x0a;Víš jak to chodí ne? V politice se bez konexí neobejdeš. Já znám každýho a každej zná mě!&#x0a;&#x0a;Ale pozor — ode mě nic neslyšels. Rozumíme si?"/>
                        <!-- Tab buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button x:Name="tab_dialog_btn" Content="Řeč" Style="{StaticResource ShopBuyButton}" Click="Tab_Dialog_Click" Margin="4,0"/>
                            <Button x:Name="tab_shop_btn" Content="Zboží" Style="{StaticResource GameButton}" Click="Tab_Shop_Click" Margin="4,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right: switchable content (dialog full text OR shop) -->
                <Grid Grid.Column="1" Margin="8,15,15,15">

                    <!-- Dialog panel -->
                    <Border x:Name="dialog_full_panel" Style="{StaticResource DialogPanel}" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="Co říká Dealeros..." Foreground="#FF00FF88" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock Style="{StaticResource DialogText}" FontSize="16" TextWrapping="Wrap">
                                <Run Text="Tak poslouchej pozorně, kamaráde."/><LineBreak/><LineBreak/>
                                <Run Text="Tady na mostě se odehrávají věci, o kterých se v médiích nepíše. Víš proč? Protože já zaplatím, aby se nepsaly."/><LineBreak/><LineBreak/>
                                <Run Text="Mám tu svůj sortiment — houbičky, odvary, speciální rybičky z Vltavy... ale i závažnější zboží. Pero na podpisy, kontakty na správné lidi."/><LineBreak/><LineBreak/>
                                <Run Text="Každý politik mě zná. Já jsem ten, kdo točí kola za oponou."/><LineBreak/><LineBreak/>
                                <Run Text="Chceš si něco koupit? Klikni na 'Zboží' vlevo."/><LineBreak/><LineBreak/>
                                <Run Text="A pamatuj —" Foreground="#FF00FF88"/><Run Text=" ode mě nic neslyšels." Foreground="#FF00FF88" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Shop panel -->
                    <Border x:Name="shop_panel" Style="{StaticResource DialogPanel}" Visibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Dealerovo tajné zboží" Foreground="#FF00FF88" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold"/>
                                <Border Background="#CC2E7D32" CornerRadius="4" Padding="8,2" Margin="15,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/fotky/piggy_money.png" Height="22" Width="22" Margin="0,0,6,0"/>
                                        <Label x:Name="dealer_money_label" Content="0" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="16" Padding="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="dealer_shop_items">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ItemCard}" Width="250" Margin="5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="65"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Source="{Binding ImagePath}" Height="55" Width="55" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" Foreground="#FF00FF88" FontFamily="Viner Hand ITC" FontSize="15" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="#BBCCCC" FontFamily="Viner Hand ITC" FontSize="11" TextWrapping="Wrap" MaxHeight="40"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <TextBlock Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="13">
                                                                <Run Text="{Binding Price}"/><Run Text=" Gold"/>
                                                            </TextBlock>
                                                            <TextBlock Foreground="#8800FF88" FontFamily="Viner Hand ITC" FontSize="11" Margin="8,0,0,0">
                                                                <Run Text="+"/><Run Text="{Binding StatBonus}"/> HP
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Content="Koupit" Style="{StaticResource ShopBuyButton}" HorizontalAlignment="Left" Margin="0,4,0,0" Tag="{Binding}" Click="DealerBuy_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Close button -->
                <Button Click="dealeros_button_click_close" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,10,0" Height="44" Width="44" Background="{x:Null}" BorderBrush="{x:Null}" Grid.Column="1" Cursor="Hand">
                    <Image Height="36" Source="/fotky/close_button.png" Stretch="Fill" Width="36"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
