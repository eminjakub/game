<Page x:Class="game.Mainmenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="mainmenu"  Height="720" Width="1280">

    <Page.Resources>
        <!-- Location button style with hover glow -->
        <Style x:Key="LocationButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#44FFD700"/>
                                <Setter TargetName="brd" Property="BorderBrush" Value="#CCFFD700"/>
                                <Setter TargetName="brd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Gold" BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#66FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Image Stretch="Fill" Source=".\fotky\bgame.png" Height="720" Width="1280"/>

        <Canvas>

            <!-- HRAD button with label -->
            <Button Style="{StaticResource LocationButton}" Canvas.Left="636" Canvas.Top="152" Height="130" Width="366" Click="hrad_move">
                <Border Background="#CC000000" CornerRadius="4" Padding="8,2">
                    <TextBlock Text="Hrad" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="16" FontWeight="Bold"/>
                </Border>
            </Button>

            <!-- MOST button with label -->
            <Button Style="{StaticResource LocationButton}" Canvas.Left="1048" Canvas.Top="518" Height="148" Width="222" Click="Button_Click_1">
                <Border Background="#CC000000" CornerRadius="4" Padding="8,2">
                    <TextBlock Text="Most" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="16" FontWeight="Bold"/>
                </Border>
            </Button>

            <!-- OBCHOD button with label -->
            <Button Style="{StaticResource LocationButton}" Canvas.Left="460" Canvas.Top="518" Height="130" Width="212" Click="obchod_move">
                <Border Background="#CC000000" CornerRadius="4" Padding="8,2">
                    <TextBlock Text="Obchod" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="16" FontWeight="Bold"/>
                </Border>
            </Button>

            <!-- ARENA button with label -->
            <Button Style="{StaticResource LocationButton}" Canvas.Left="104" Canvas.Top="263" Height="136" Width="175" Click="Arena_button">
                <Border Background="#CC000000" CornerRadius="4" Padding="8,2">
                    <TextBlock Text="Aréna" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="16" FontWeight="Bold"/>
                </Border>
            </Button>

            <!-- Save/Exit button -->
            <Button Canvas.Left="10" Canvas.Top="650" Height="60" Width="63" Click="home_exit" Background="{x:Null}" BorderBrush="{x:Null}" Cursor="Hand">
                <Image Height="60" Source="./fotky/save.png" Stretch="Fill" Width="63"/>
            </Button>

            <!-- Top right status panel -->
            <Border Canvas.Left="1052" Canvas.Top="-5" Height="126" Width="254" Background="#CC333333" BorderBrush="#88FFFFFF" BorderThickness="2" CornerRadius="6"/>

            <ProgressBar x:Name="exp_bar_menu" Height="16" Width="207" HorizontalAlignment="Left" Canvas.Left="1063" Canvas.Top="94" VerticalAlignment="Top" Foreground="#FF007DCC" Value="90" Background="#FF333333"/>
            <Label Content="Level" HorizontalAlignment="Left" Canvas.Left="1063" Canvas.Top="60" VerticalAlignment="Top" FontFamily="Viner Hand ITC" FontSize="20" Foreground="White"/>
            <Label x:Name="label_money" Content="0" HorizontalAlignment="Left" Canvas.Left="1166" VerticalAlignment="Center" FontFamily="Viner Hand ITC" FontSize="25" Height="42" Width="112" Canvas.Top="13" Foreground="#FFFFD700"/>
            <Label x:Name="lv_status" Content="1" HorizontalAlignment="Left" Canvas.Left="1238" Canvas.Top="57" VerticalAlignment="Center" Height="33" Width="32" FontSize="25" FontFamily="Viner Hand ITC" Foreground="White"/>
            <Image Height="82" Canvas.Left="1037" Source="/fotky/piggy_money.png" Stretch="Fill" Canvas.Top="-7" Width="113"/>

            <!-- Inventory bag button -->
            <Image Source="./fotky/taska.png" Height="100" Width="94" Canvas.Left="1166" Canvas.Top="140"/>
            <Button Style="{StaticResource LocationButton}" Canvas.Top="140" Height="100" Width="94" Click="inventory_button_Click" Canvas.Left="1166">
                <TextBlock Text="" Foreground="Transparent"/>
            </Button>

        </Canvas>

        <!-- Inventory overlay -->
        <Border x:Name="inventoryOverlay" Visibility="Hidden" Background="#EE111111" CornerRadius="10" Margin="100,80,100,60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Profile + Stats -->
                <StackPanel Grid.Column="0" Margin="20">
                    <TextBlock Text="Profil" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Border BorderBrush="#88FFFFFF" BorderThickness="2" CornerRadius="6" HorizontalAlignment="Center" Padding="5" Margin="0,0,0,15">
                        <Image Source="/fotky/profile_foto.png" Stretch="Uniform" Height="140" Width="140"/>
                    </Border>

                    <TextBlock Text="Síla" Foreground="#FFFF6666" FontFamily="Viner Hand ITC" FontSize="18" Margin="0,5,0,2"/>
                    <ProgressBar x:Name="progress_bar_strenght" Style="{StaticResource GameStatBar}" Width="280" Value="1" Foreground="#FFDC0000" Maximum="100"/>
                    <Button x:Name="strengt_add_bt" Content="+ Síla (100 Gold)" Style="{StaticResource GameButton}" FontSize="13" Margin="0,3,0,8" Click="strenght_add" HorizontalAlignment="Left"/>

                    <TextBlock Text="Obratnost" Foreground="#FF66BBFF" FontFamily="Viner Hand ITC" FontSize="18" Margin="0,5,0,2"/>
                    <ProgressBar x:Name="progress_bar_dexterity" Style="{StaticResource GameStatBar}" Width="280" Value="1" Foreground="#FF007DCC" Maximum="100"/>
                    <Button x:Name="dexterity_add_bt" Content="+ Obratnost (100 Gold)" Style="{StaticResource GameButton}" FontSize="13" Margin="0,3,0,8" Click="dexterity_add" HorizontalAlignment="Left"/>

                    <TextBlock Text="Brnění" Foreground="#FFDDEE00" FontFamily="Viner Hand ITC" FontSize="18" Margin="0,5,0,2"/>
                    <ProgressBar x:Name="progress_bar_armor" Style="{StaticResource GameStatBar}" Width="280" Value="1" Foreground="#FFD4E000" Maximum="100"/>
                    <Button x:Name="armor_add_bt" Content="+ Brnění (100 Gold)" Style="{StaticResource GameButton}" FontSize="13" Margin="0,3,0,8" Click="armor_add" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Right: Inventory Items -->
                <Grid Grid.Column="1" Margin="10,20,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Inventář" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="inventory_items_control">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ItemCard}" Width="210" Height="130" Margin="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding ImagePath}" Height="50" Width="50" Stretch="Uniform" VerticalAlignment="Top" Margin="0,5,5,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontFamily="Viner Hand ITC" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Type}" Foreground="#AAAAAA" FontFamily="Viner Hand ITC" FontSize="11"/>
                                                <TextBlock Foreground="#88AAFFAA" FontFamily="Viner Hand ITC" FontSize="11">
                                                    <Run Text="+"/><Run Text="{Binding Value}"/><Run Text=" "/><Run Text="{Binding StatType}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Button Content="Nasadit" Style="{StaticResource ShopBuyButton}" FontSize="11" Tag="{Binding}" Click="Equip_Click" Margin="0,0,4,0"/>
                                                    <Button Content="Použít" Style="{StaticResource GameButton}" FontSize="11" Tag="{Binding}" Click="UseItem_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Close button -->
                <Button Click="close_bt" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Height="50" Width="50" Background="{x:Null}" BorderBrush="{x:Null}" Grid.Column="1" Cursor="Hand">
                    <Image Height="40" Source="/fotky/close_button.png" Stretch="Fill" Width="40"/>
                </Button>
            </Grid>
        </Border>

        <!-- Save button -->
        <Button Click="save_button" HorizontalAlignment="Left" Margin="86,650,0,0" VerticalAlignment="Top" Height="60" Width="62" Background="{x:Null}" BorderBrush="{x:Null}" Cursor="Hand">
            <Image Height="60" Source="./fotky/save_bt.png" Stretch="Fill" Width="52"/>
        </Button>

        <TextBlock x:Name="achv" Visibility="Hidden" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Height="69" Width="201" Background="#FF424242" Foreground="White" FontFamily="Viner Hand ITC"><Run Text="      "/><Run Text="ACHIEVEMENT UNLOCKED"/><LineBreak/><Run Text=" "/><LineBreak/><Run Text="&#x9;Poraz pana Flákance"/></TextBlock>

    </Grid>
</Page>
