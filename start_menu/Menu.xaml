<Page x:Class="game.Menu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="menu">

    <Grid>
        <Image Stretch="Fill" Source="\fotky\homepage.png"/>

        <!-- Title -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,45,0,0"
                Background="#CC000000" BorderBrush="#88FFD700" BorderThickness="2" CornerRadius="6" Padding="12,6">
            <TextBlock Text="Dungeon of Czech" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="28" FontWeight="Bold"/>
        </Border>

        <!-- Menu buttons -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,130,0,0" Width="190">

            <Button Click="Button_Click" Cursor="Hand" Margin="0,0,0,12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="#CC1A1A2E" BorderBrush="#AAFFD700" BorderThickness="2" CornerRadius="6" Padding="0,12">
                            <TextBlock Text="Začít" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC3A3A6E"/>
                                <Setter TargetName="brd" Property="BorderBrush" Value="#FFFFD700"/>
                                <Setter TargetName="brd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Gold" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC0A0A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Click="Button_Click_1" Cursor="Hand" Margin="0,0,0,12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="#CC1A1A2E" BorderBrush="#AAFFD700" BorderThickness="2" CornerRadius="6" Padding="0,12">
                            <TextBlock Text="Lore" Foreground="#FFFFD700" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC3A3A6E"/>
                                <Setter TargetName="brd" Property="BorderBrush" Value="#FFFFD700"/>
                                <Setter TargetName="brd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Gold" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC0A0A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Click="Button_Click_2" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd" Background="#CC2E1A1A" BorderBrush="#AAFF4444" BorderThickness="2" CornerRadius="6" Padding="0,12">
                            <TextBlock Text="Konec" Foreground="#FFFF6666" FontFamily="Viner Hand ITC" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC5E2A2A"/>
                                <Setter TargetName="brd" Property="BorderBrush" Value="#FFFF4444"/>
                                <Setter TargetName="brd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Red" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#CC1A0A0A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Page>
